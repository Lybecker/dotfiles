# Shared environment variables sourced by both .bashrc and .zshrc.

# Locale
export LANG="${LANG:-en_US.UTF-8}"

# Editor
if command -v code >/dev/null 2>&1; then
  export EDITOR='code --wait'
  export VISUAL="$EDITOR"
elif command -v vim >/dev/null 2>&1; then
  export EDITOR='vim'
  export VISUAL='vim'
fi

# Pager
export PAGER='less'
export LESS='-R'

# Homebrew (Mac) — sets its own PATH entries
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Silence Homebrew analytics
export HOMEBREW_NO_ANALYTICS=1

# Prepend $HOME/bin last so it wins over brew paths
export PATH="$HOME/bin:$PATH"

# Force a black terminal background via OSC 11 / foreground via OSC 10.
# Only in interactive terminals on a real TTY. Supported by iTerm2, Terminal.app,
# xterm, most modern emulators. Harmless no-op in terminals that don't parse it.
case "$-" in
  *i*)
    if [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ] && [ -z "${VSCODE_INJECTION:-}" ]; then
      printf '\033]11;#000000\007'
      printf '\033]10;#e5e5e5\007'
    fi
    ;;
esac
